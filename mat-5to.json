              ]
            },
            {
              "exercise_id": "ex01_02_02",
              "interaction_type": "fill_in_blank",
              "instruction": "Cuidado con esta trampa. Completa el resultado de multiplicar estos dos irracionales.",
              "math_expression": "\\sqrt{3} \\cdot \\sqrt{12} = \\sqrt{36} = [?]",
              "correct_answer": "6",
              "options": ["6", "15", "36"],
              "explanation": [
                "A simple vista, multiplicas dos números irracionales.",
                "Sin embargo, por propiedades de raíces, al unirlos bajo la misma raíz (3 * 12) obtenemos 36.",
                "La raíz cuadrada de 36 es exactamente 6, un número entero (racional)."
              ]
            },
            {
              "exercise_id": "ex01_02_03",
              "interaction_type": "pattern_grid",
              "instruction": "Analiza el patrón de multiplicar por Pi (π). ¿Qué pasa en el último recuadro?",
              "grid_data": [
                { "cell": "2 \\cdot \\pi", "value": "Irracional" },
                { "cell": "1 \\cdot \\pi", "value": "Irracional" },
                { "cell": "0 \\cdot \\pi", "value": "[?]" }
              ],
              "correct_answer": "Racional",
              "options": ["Racional", "Irracional"],
              "explanation": [
                "Cualquier número irracional multiplicado por un racional diferente de cero, sigue siendo irracional.",
                "Pero la regla básica nos dice que TODO número multiplicado por cero, es siempre cero.",
                "Como 0 es un número entero, el resultado se vuelve Racional."
              ]
            },
            {
              "exercise_id": "ex01_02_04",
              "interaction_type": "equation_builder",
              "instruction": "Resuelve esta división de irracionales armando la secuencia correcta.",
              "math_expression": "\\frac{\\sqrt{18}}{\\sqrt{2}} = \\sqrt{[?]} = [?]",
              "available_tiles": ["9", "3", "6", "18"],
              "correct_sequence": ["9", "3"],
              "explanation": [
                "Por propiedades de radicación, puedes colocar toda la fracción dentro de una sola raíz: √(18 / 2).",
                "18 dividido entre 2 es 9.",
                "La raíz cuadrada de 9 es exactamente 3 (un número racional)."
              ]
            },
            {
              "exercise_id": "ex01_02_05",
              "interaction_type": "matching_pairs",
              "instruction": "Empareja la operación con el tipo de número que resulta",
              "pairs": [
                { "left": "\\sqrt{5} - \\sqrt{5}", "right": "Racional" },
                { "left": "5 \\cdot \\sqrt{7}", "right": "Irracional" },
                { "left": "\\sqrt{2} \\cdot \\sqrt{8}", "right": "Racional" },
                { "left": "4 + \\pi", "right": "Irracional" }
              ],
              "explanation": [
                "Un irracional restado por sí mismo da 0 (Racional).",
                "La multiplicación √2 * √8 da √16, que es exactamente 4 (Racional).",
                "Las otras operaciones (5√7 y 4+π) conservan sus decimales infinitos, por lo que son irracionales."
              ]
            },
            {
              "exercise_id": "ex01_02_06",
              "interaction_type": "number_line",
              "instruction": "Resuelve la multiplicación y ubica el resultado en la recta.",
              "math_expression": "\\sqrt{7} \\cdot \\sqrt{7} = [?]",
              "correct_answer": 7,
              "line_config": {
                "min": 0,
                "max": 10,
                "step": 1
              },
              "explanation": [
                "Multiplicar una raíz cuadrada por sí misma es equivalente a elevar esa raíz al cuadrado.",
                "La raíz cuadrada y la potencia al cuadrado se cancelan mutuamente.",
                "El número 7 queda libre (es un número racional)."
              ]
            }
          ]
        },
