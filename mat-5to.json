                { "left": "\\sqrt{7}", "right": "Irracional" },
                { "left": "100", "right": "Racional" }
              ],
              "explanation": [
                "Pi y las raíces no exactas (como √7) son irracionales.",
                "Los decimales exactos (-2.75) y los enteros (100) son siempre racionales porque pueden escribirse como fracción."
              ]
            },
            {
              "exercise_id": "ex01_01_06",
              "interaction_type": "equation_builder",
              "instruction": "Un decimal exacto es racional. Arma su equivalencia en fracción.",
