              "available_tiles": ["5", "2", "4", "25"],
              "correct_sequence": ["5", "2"],
              "explanation": [
                "-2.5 se lee como 'menos cinco medios'.",
                "Se escribe como la fracción impropia -5/2."
              ]
            }
          ]
